# Copy this file to:
# D:\TRAEDATA\rw\.env.deploy
#
# Open it with:
# notepad D:\TRAEDATA\rw\.env.deploy
#
# Never commit .env.deploy. It contains deployment tokens.

# GitHub repository, optional if origin is already correct.
# Repository URL:
# https://github.com/2711944586/rw
#
# Create a GitHub token:
# Classic token page:
# https://github.com/settings/tokens/new
# Fine-grained token page:
# https://github.com/settings/personal-access-tokens/new
#
# Minimum practical permission:
# - Existing repo push only: Contents read/write on this repo.
# - Auto-create private repo: repository creation permission, or use a classic token with repo scope.
GITHUB_REPO=2711944586/rw
GITHUB_PRIVATE=true
GITHUB_TOKEN=
DEPLOY_COMMIT_MESSAGE=Automated deployment

# Supabase automation.
# Create/login dashboard:
# https://supabase.com/dashboard
#
# Create Supabase access token:
# https://supabase.com/dashboard/account/tokens
#
# List organizations after login:
# npx supabase login
# npx supabase orgs list
#
# Project dashboard URL format:
# https://supabase.com/dashboard/project/YOUR_PROJECT_REF
#
# Project API settings:
# https://supabase.com/dashboard/project/YOUR_PROJECT_REF/settings/api
#
# Auth URL Configuration:
# https://supabase.com/dashboard/project/YOUR_PROJECT_REF/auth/url-configuration
#
# If SUPABASE_PROJECT_REF is empty, the script can create a new project when
# SUPABASE_ORG_ID, SUPABASE_PROJECT_NAME, SUPABASE_DB_PASSWORD and SUPABASE_REGION are filled.
SUPABASE_ACCESS_TOKEN=
SUPABASE_ORG_ID=
SUPABASE_PROJECT_NAME=rw-study
SUPABASE_REGION=ap-southeast-1
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_SCHEMA_MODE=schema

# Browser-facing Supabase config. If URL is empty, it is derived from SUPABASE_PROJECT_REF.
# If key is empty, the script tries to read it from Supabase CLI.
# VITE_SUPABASE_URL is Project URL from Supabase API settings.
# VITE_SUPABASE_PUBLISHABLE_KEY is Publishable key from Supabase API settings.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Vercel automation.
# Vercel dashboard:
# https://vercel.com/dashboard
#
# Create Vercel token:
# https://vercel.com/account/tokens
#
# Project settings URL after project exists:
# https://vercel.com/PROJECT_OWNER/VERCEL_PROJECT_NAME/settings
#
# Environment variables URL after project exists:
# https://vercel.com/PROJECT_OWNER/VERCEL_PROJECT_NAME/settings/environment-variables
VERCEL_TOKEN=
VERCEL_PROJECT_NAME=rw
VERCEL_TEAM_ID=
PRODUCTION_URL=
