{
  "name": "pku-swm-420-study-system",
  "version": "3.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start-local.ps1",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "node scripts/check-js.mjs",
    "deploy:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/deploy-all.ps1",
    "deploy:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/deploy-all.ps1 -Production",
    "verify:production": "node scripts/verify-production.mjs",
    "quality": "npm run check && npm test && npm run build && npm audit --audit-level=moderate",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:props": "vitest --run tests/properties"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.84.0",
    "lucide": "^1.16.0",
    "vite": "^7.2.4"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.1",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "vitest": "^4.1.7"
  }
}
